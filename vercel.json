{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/gmail-callback", "dest": "/api/gmail-callback" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "functions": {
    "api/*.js": { "maxDuration": 30 }
  }
}
